{
  "name": "@satoshai/abi-cli",
  "version": "0.3.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "CLI to fetch Stacks contract ABIs and generate TypeScript definitions.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.18.3",
  "bin": {
    "abi-cli": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "prepublishOnly": "pnpm build",
    "release": "changeset publish --provenance",
    "prepare": "husky || true"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "jiti": "^2.6.1"
  },
  "peerDependencies": {
    "@stacks/transactions": ">=7.0.0"
  },
  "devDependencies": {
    "@stacks/transactions": "^7.3.1",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.3.0",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.55.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "stacks",
    "abi",
    "cli",
    "typescript",
    "blockchain",
    "clarity",
    "codegen"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/satoshai-dev/abi-cli"
  },
  "homepage": "https://github.com/satoshai-dev/abi-cli#readme",
  "bugs": {
    "url": "https://github.com/satoshai-dev/abi-cli/issues"
  }
}
