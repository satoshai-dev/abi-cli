{
  "name": "@satoshai/abi-cli",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "CLI to fetch Stacks contract ABIs and generate TypeScript definitions.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "abi-cli": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "citty": "^0.1.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "stacks",
    "abi",
    "cli",
    "typescript",
    "blockchain",
    "clarity",
    "codegen"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/satoshai-dev/abi-cli"
  }
}
